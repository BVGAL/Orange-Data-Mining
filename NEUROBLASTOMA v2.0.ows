		<properties node_id="36" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\x0b\x00\x00\x00/\x00\x00\x04\xf6\x00\x00\x03\x1f\x00\x00\x01\x0c\x00\x00\x00M\x00\x00\x04\xf5\x00\x00\x03\x1e\x00\x00\x00\x00\x00\x00\x00\x00\x06\x00\x00\x00\x01\x0c\x00\x00\x00M\x00\x00\x04\xf5\x00\x00\x03\x1e', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import pandas as pd\nfrom scipy.stats import mannwhitneyu\n\n# Carica il file CSV \ndf = pd.read_csv(r"C:/Users/39331/Desktop/Stefano/UNIMIB/STAGE/Analisi Cluster Malattie/1 - NEUROBLASTOMA/10_7717_peerj_5665_dataYM2018_neuroblastoma.csv")\n\n# Controlla i nomi delle colonne\nprint(df.columns)\n\n# Assumiamo che la colonna "outcome" sia 1 per "alive" e 0 per "dead"\n# Filtriamo i dati per creare due gruppi\ngroup_alive = df[df["outcome"] == 1]["time_months"]\ngroup_dead = df[df["outcome"] == 0]["time_months"]\n\n# Eseguiamo il test di Mann-Whitney U per confrontare le mediane\nstat, p_value = mannwhitneyu(group_alive, group_dead, alternative="greater")\n\n# Stampa il risultato\nprint(f"Test di Mann-Whitney U: Statistica={stat}, P-value={p_value}")\n\n# Interpretazione del p-value\nif p_value &lt; 0.05:\n    print("❗ La differenza tra \'time_months\' nei due gruppi è statisticamente significativa.")\nelse:\n    print("✅ Non c\'è una differenza significativa tra \'time_months\' nei due gruppi.")\n', 'filename': None}], 'scriptText': 'import pandas as pd\nfrom scipy.stats import mannwhitneyu\n\n# Carica il file CSV \ndf = pd.read_csv(r"C:/Users/39331/Desktop/Stefano/UNIMIB/STAGE/Analisi Cluster Malattie/1 - NEUROBLASTOMA/10_7717_peerj_5665_dataYM2018_neuroblastoma.csv")\n\n# Controlla i nomi delle colonne\nprint(df.columns)\n\n# Assumiamo che la colonna "outcome" sia 1 per "alive" e 0 per "dead"\n# Filtriamo i dati per creare due gruppi\ngroup_alive = df[df["outcome"] == 1]["time_months"]\ngroup_dead = df[df["outcome"] == 0]["time_months"]\n\n# Eseguiamo il test di Mann-Whitney U per confrontare le mediane\nstat, p_value = mannwhitneyu(group_alive, group_dead, alternative="greater")\n\n# Stampa il risultato\nprint(f"Test di Mann-Whitney U: Statistica={stat}, P-value={p_value}")\n\n# Interpretazione del p-value\nif p_value &lt; 0.05:\n    print("❗ La differenza tra \'time_months\' nei due gruppi è statisticamente significativa.")\nelse:\n    print("✅ Non c\'è una differenza significativa tra \'time_months\' nei due gruppi.")\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9d\x00\x00\x00]\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
