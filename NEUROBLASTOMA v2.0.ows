		<properties node_id="7" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\xff\xff\xff\xff\xff\xff\xff\xf9\x00\x00\x06\x00\x00\x00\x030\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x05\xff\x00\x00\x03/\x00\x00\x00\x00\x02\x00\x00\x00\x06\x00\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x05\xff\x00\x00\x03/', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="8" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01p\x00\x00\x00`\x00\x00\x04i\x00\x00\x02_\x00\x00\x01q\x00\x00\x00~\x00\x00\x04h\x00\x00\x02^\x00\x00\x00\x00\x00\x00\x00\x00\x06\x00\x00\x00\x01q\x00\x00\x00~\x00\x00\x04h\x00\x00\x02^', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import numpy as np\nfrom sklearn.cluster import MeanShift, estimate_bandwidth\nfrom Orange.data import Table, Domain, ContinuousVariable\n\n# Caricare i dati da Orange\ndata = in_data  # Input dal widget Orange (tabella di dati)\nX = np.array(data.X)  # Convertire i valori numerici in una matrice NumPy\n\n# Stimare la bandwidth (finestra di densità) per Mean-Shift\n# La bandwidth controlla la dimensione della "finestra" utilizzata per stimare la densità dei cluster\n# Il parametro quantile determina quanto vicini devono essere i punti per considerarli come parte dello stesso cluster\nbandwidth = estimate_bandwidth(X, quantile=0.2, n_samples=500)  # Puoi modificare bandwidth manualmente, ad esempio bandwidth=2.0\n\n# Applicare l\'algoritmo Mean-Shift\nmean_shift_model = MeanShift(bandwidth=bandwidth, bin_seeding=True)  # Configura Mean-Shift con il valore stimato di bandwidth\nmean_shift_model.fit(X)  # Esegui il clustering sui dati\n\n# Ottenere le etichette dei cluster\ncluster_labels = mean_shift_model.labels_  # Etichetta del cluster per ogni punto (stesso valore per punti nello stesso cluster)\n\n# Ottenere i centroidi dei cluster\ncluster_centers = mean_shift_model.cluster_centers_  # Coordinate dei massimi locali della densità (i centroidi dei cluster)\n\n# Creare un nuovo dominio con un attributo aggiuntivo per i cluster\n# Aggiungiamo una nuova variabile continua chiamata "Cluster" come attributo aggiuntivo\ncluster_var = ContinuousVariable("Cluster")  # Definisce una nuova variabile chiamata "Cluster"\nnew_domain = Domain(data.domain.attributes, data.domain.class_vars, metas=[cluster_var])  # Crea un nuovo dominio che include i cluster come metadati\n\n# Aggiungere le etichette dei cluster come metadati\nclusters_column = cluster_labels.reshape(-1, 1)  # Trasforma le etichette in una colonna\nnew_table = Table.from_numpy(new_domain, X, Y=data.Y, metas=clusters_column)  # Crea una nuova tabella Orange con i dati originali e i cluster\n\n# Passare i dati con i cluster come output\nout_data = new_table  # Esporta la tabella con i cluster al workflow di Orange\n\n# Stampare informazioni sui cluster\nprint(f"Numero di cluster: {len(np.unique(cluster_labels))}")  # Stampa il numero totale di cluster trovati\nprint(f"Centroidi dei cluster:\\n{cluster_centers}")  # Stampa i centroidi dei cluster (coordinate dei massimi locali della densità)\n\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom sklearn.cluster import MeanShift, estimate_bandwidth\nfrom Orange.data import Table, Domain, ContinuousVariable\n\n# Caricare i dati da Orange\ndata = in_data  # Input dal widget Orange (tabella di dati)\nX = np.array(data.X)  # Convertire i valori numerici in una matrice NumPy\n\n# Stimare la bandwidth (finestra di densità) per Mean-Shift\n# La bandwidth controlla la dimensione della "finestra" utilizzata per stimare la densità dei cluster\n# Il parametro quantile determina quanto vicini devono essere i punti per considerarli come parte dello stesso cluster\nbandwidth = estimate_bandwidth(X, quantile=0.2, n_samples=500)  # Puoi modificare bandwidth manualmente, ad esempio bandwidth=2.0\n\n# Applicare l\'algoritmo Mean-Shift\nmean_shift_model = MeanShift(bandwidth=bandwidth, bin_seeding=True)  # Configura Mean-Shift con il valore stimato di bandwidth\nmean_shift_model.fit(X)  # Esegui il clustering sui dati\n\n# Ottenere le etichette dei cluster\ncluster_labels = mean_shift_model.labels_  # Etichetta del cluster per ogni punto (stesso valore per punti nello stesso cluster)\n\n# Ottenere i centroidi dei cluster\ncluster_centers = mean_shift_model.cluster_centers_  # Coordinate dei massimi locali della densità (i centroidi dei cluster)\n\n# Creare un nuovo dominio con un attributo aggiuntivo per i cluster\n# Aggiungiamo una nuova variabile continua chiamata "Cluster" come attributo aggiuntivo\ncluster_var = ContinuousVariable("Cluster")  # Definisce una nuova variabile chiamata "Cluster"\nnew_domain = Domain(data.domain.attributes, data.domain.class_vars, metas=[cluster_var])  # Crea un nuovo dominio che include i cluster come metadati\n\n# Aggiungere le etichette dei cluster come metadati\nclusters_column = cluster_labels.reshape(-1, 1)  # Trasforma le etichette in una colonna\nnew_table = Table.from_numpy(new_domain, X, Y=data.Y, metas=clusters_column)  # Crea una nuova tabella Orange con i dati originali e i cluster\n\n# Passare i dati con i cluster come output\nout_data = new_table  # Esporta la tabella con i cluster al workflow di Orange\n\n# Stampare informazioni sui cluster\nprint(f"Numero di cluster: {len(np.unique(cluster_labels))}")  # Stampa il numero totale di cluster trovati\nprint(f"Centroidi dei cluster:\\n{cluster_centers}")  # Stampa i centroidi dei cluster (coordinate dei massimi locali della densità)\n\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9d\x00\x00\x00]\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
